# Netlify: hash'li asset'ler uzun önbellek; shell asla — eski HTML yeni chunk'a işaret edince boş sayfa olur.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
